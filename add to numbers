class Solution:
    def addTwoNumbers(self, l1, l2):
        d = ListNode()
        cur = d
        c = 0
        while l1 or l2 or c:
            a = l1.val if l1 else 0
            b = l2.val if l2 else 0
            s = a + b + c
            c = s // 10
            cur.next = ListNode(s % 10)
            cur = cur.next
            if l1: l1 = l1.next
            if l2: l2 = l2.next
        return d.next
